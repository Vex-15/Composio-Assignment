# ============================================================
# Composio App Research Pipeline — Environment Variables
# ============================================================
# Copy this file to .env and fill in your keys.
# Never commit .env to version control.

# --- Required -----------------------------------------------------------
# Google Gemini API key for LLM extraction (free tier: gemini-2.0-flash)
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# --- Recommended --------------------------------------------------------
# Composio API key for Stage 1 catalog lookup (free account)
# Get one at: https://composio.dev → Settings → API Keys
COMPOSIO_API_KEY=your_composio_api_key_here

# --- Optional -----------------------------------------------------------
# Serper API key for web search fallback when direct doc URLs fail
# Get one at: https://serper.dev (free tier: 2500 queries)
SERPER_API_KEY=your_serper_api_key_here
